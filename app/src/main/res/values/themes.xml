<resources>

    <!--
      Minimal launch theme. The UI is fully Jetpack Compose (see VectorTheme), which resolves the
      real color scheme, night mode and accent at runtime. This style only governs the brief launch
      window before Compose draws, so it just needs a sane Material3 base with no action bar.
    -->
    <style name="AppTheme" parent="@android:style/Theme.DeviceDefault.DayNight">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

</resources>
